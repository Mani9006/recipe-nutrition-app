{
  "name": "nutrichef-recipe-nutrition-app",
  "version": "1.0.0",
  "description": "A mobile-first recipe browser, nutrition calculator, and meal planner PWA",
  "author": "Mani <myfamily9006@gmail.com>",
  "license": "MIT",
  "private": false,
  "keywords": [
    "recipe",
    "nutrition",
    "meal-planner",
    "pwa",
    "react",
    "health",
    "fitness",
    "cooking"
  ],
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "test:watch": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "lint": "eslint src/ tests/ --ext .js,.jsx",
    "lint:fix": "eslint src/ tests/ --ext .js,.jsx --fix",
    "eject": "react-scripts eject",
    "simulate-commits": "node simulate_commits.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testMatch": [
      "**/tests/**/test_*.[jt]s?(x)",
      "**/?(*.)+(test|spec).[jt]s?(x)",
      "**/__tests__/**/*.[jt]s?(x)"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  }
}
